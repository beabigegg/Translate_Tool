# Copy to .env and adapt per environment.
# Never put real secrets in this file.

APP_ENV=development
LOG_LEVEL=INFO

# --- Ollama (local, layout inference only) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama context window (tokens) ---
# GENERAL_NUM_CTX and TRANSLATION_NUM_CTX override context window independently.
# Fallback chain: specific var → OLLAMA_NUM_CTX → built-in default (4096 / 3072).
# OLLAMA_NUM_CTX is a backward-compat fallback; prefer the specific vars for new deployments.
#OLLAMA_NUM_CTX=4096
#GENERAL_NUM_CTX=4096
#TRANSLATION_NUM_CTX=3072

# --- Server binding ---
TRANSLATE_TOOL_HOST=127.0.0.1
TRANSLATE_TOOL_PORT=8765

# --- Translation cache ---
TRANSLATION_CACHE_ENABLED=1

# --- Job store ---
MAX_JOBS_IN_MEMORY=100
JOB_TTL_HOURS=24

# --- Panjit OpenAI-compatible gateway (free, primary translation provider) ---
PANJIT_LLM_BASE_URL=https://ollama_pjapi.theaken.com
PANJIT_API=<your-panjit-api-key>

# --- DeepSeek API (paid, optional upgrade — disabled by default) ---
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API=<your-deepseek-api-key>
DEEPSEEK_ENABLED=false

# --- Term injection gate ---
#TERM_INJECT_HIGH_CONFIDENCE_UNVERIFIED=false
#TERM_INJECT_CONF_THRESHOLD=0.9
