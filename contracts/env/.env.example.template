# Copy to .env and adapt per environment.
# Never put real secrets in this file.

APP_ENV=development
LOG_LEVEL=INFO

# --- Ollama (local, layout inference only) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama context window (tokens) ---
# GENERAL_NUM_CTX and TRANSLATION_NUM_CTX override context window independently.
# Fallback chain: specific var → OLLAMA_NUM_CTX → built-in default (4096 / 3072).
# OLLAMA_NUM_CTX is a backward-compat fallback; prefer the specific vars for new deployments.
#OLLAMA_NUM_CTX=4096
#GENERAL_NUM_CTX=4096
#TRANSLATION_NUM_CTX=3072

# --- Server binding ---
TRANSLATE_TOOL_HOST=127.0.0.1
TRANSLATE_TOOL_PORT=8765

# --- Translation cache ---
TRANSLATION_CACHE_ENABLED=1

# --- Job store ---
MAX_JOBS_IN_MEMORY=100
JOB_TTL_HOURS=24

# --- Panjit OpenAI-compatible gateway (free, primary translation provider) ---
PANJIT_LLM_BASE_URL=https://ollama_pjapi.theaken.com
PANJIT_API=<your-panjit-api-key>

# --- DeepSeek API (cloud, optional — fallback chain position 2, disabled by default) ---
# Set DEEPSEEK_ENABLED=true AND provide a valid DEEPSEEK_API key to activate.
# When DEEPSEEK_ENABLED=false, PANJIT failure causes immediate job failure (no local fallback).
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API=<your-deepseek-api-key>
DEEPSEEK_ENABLED=false

# --- Term injection gate ---
#TERM_INJECT_HIGH_CONFIDENCE_UNVERIFIED=false
#TERM_INJECT_CONF_THRESHOLD=0.9

# --- Layout detector (p2-layout-detection) ---
# Set LAYOUT_DETECTOR_MODEL_PATH to a preloaded weight directory for air-gapped / Docker deployments.
# Leave unset to use HuggingFace auto-download (requires network on first run only).
#LAYOUT_DETECTOR_MODEL_PATH=/opt/models/heron-101
# Set to 0 or false to disable layout detection and revert to the round(y0,10pt) heuristic (rollback switch).
#LAYOUT_DETECTOR_ENABLED=true

# --- Long-document chunking (p2-long-doc-chunking) ---
# Number of overlap tokens shared between adjacent chunks. Default: 50.
# Has no effect when the document fits within num_ctx (single-chunk path).
#CHUNK_OVERLAP_TOKENS=50

# --- Term extraction DB-first (term-extraction-db-first) ---
# Embedding model on PANJIT used to vectorise source segments for DB lookup.
#TERM_EMBEDDING_MODEL=Qwen3-Embedding-8B
# Cosine similarity threshold: >= this value is a DB hit (inject without extraction call).
#TERM_EMBEDDING_THRESHOLD=0.75
# LLM model on PANJIT used for term extraction on DB miss.
#TERM_EXTRACTION_MODEL=gemma4:latest

# --- Quality Evaluation (COMET/xCOMET) (p2-comet-qe; quality-metrics-gating AC-3, AC-4) ---
# QE is now ON by default. The critique adoption gate uses CometKiwi to decide whether
# to keep a revised draft; falls back to length-ratio heuristic when COMET is absent (AC-8).
# Set QE_ENABLED=false to opt out (reverts critique loop to unconditional adoption).
# QE_RESCORE_THRESHOLD: segments below this score are re-translated post-job (AC-2).
#QE_ENABLED=true
#QE_MODEL_NAME=Unbabel/wmt22-cometkiwi-da
#QE_DEVICE=cpu
#QE_RESCORE_THRESHOLD=0.5

# --- Post-render layout QA (output-side layout-fidelity confirmation) ---
# After each PDF-to-PDF render, the output file is re-opened and measured for
# layout fidelity (BIoU vs source bboxes, residual source text under masks,
# truncation rate). Results appear in the job status (layout_qa field).
# Fail-soft: QA errors never fail a job. Set to false to skip the QA pass.
#LAYOUT_QA_ENABLED=true

# --- LLM Judge (p3-llm-judge) ---
# Quality judge for translated text. Off by default. When enabled, the judge evaluates
# each translation and triggers re-translation (up to JUDGE_MAX_ITERATIONS times) when
# score is 中 or 低.
#JUDGE_ENABLED=false
# JUDGE_PROVIDER=ollama (default) uses a local Ollama model (JUDGE_MODEL, must be pulled).
# JUDGE_PROVIDER=cloud routes the text judge pass through the providers.yml provider named
# by JUDGE_CLOUD_PROVIDER_ID instead — set JUDGE_MODEL to that provider's model name.
# judge_layout() (page-image scoring) always stays local (JUDGE_LAYOUT_MODEL) regardless.
#JUDGE_PROVIDER=ollama
#JUDGE_MODEL=gemma3
#JUDGE_LAYOUT_MODEL=gemma3
#JUDGE_CLOUD_PROVIDER_ID=panjit
#JUDGE_MAX_ITERATIONS=3

# --- LibreOffice legacy-format conversion (support-legacy-office-formats) ---
# Optional external binary — required only to convert legacy .doc/.xls/.ppt uploads.
# Leave LIBREOFFICE_PATH unset to auto-detect via PATH / common install locations.
#LIBREOFFICE_PATH=/usr/bin/soffice
#LIBREOFFICE_TIMEOUT=120
